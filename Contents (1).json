import SwiftUI

// MARK: - Design-System (DS)
//
// Zentrale Tokens für Farben, Typografie, Abstände und Radii.
// Regeln: In Views nie Color(red:), .system(size:) oder Magic Numbers —
// immer DS.* verwenden. Siehe CLAUDE.md, Abschnitt "Design-System".
//
// Ersatz-Zuordnung für das entfernte RemindlyStyle (Phase 3):
//   RemindlyStyle.accent / accentGradient -> DS.Color.accent
//   RemindlyStyle.danger                  -> DS.Color.destructive
//   RemindlyStyle.success                 -> DS.Color.success
//   RemindlyStyle.warning                 -> DS.Color.warning
//   RemindlyStyle.cardFill/elevatedFill   -> DS.Color.card
//   RemindlyStyle.border                  -> DS.Color.border
//   RemindlyStyle.mutedText/faintText     -> DS.Color.textSecondary
//   RemindlyStyle.backgroundGradient/ink  -> DS.Color.background
//   cardRadius 26 / controlRadius 18 / pillRadius 16 -> DS.Radius.*

enum DS {

    // MARK: Farben (Asset-ColorSets mit Light/Dark-Variante)

    enum Color {
        static let accent = SwiftUI.Color("DSAccent")
        static let background = SwiftUI.Color("DSBackground")
        static let card = SwiftUI.Color("DSCard")
        static let textPrimary = SwiftUI.Color("DSTextPrimary")
        static let textSecondary = SwiftUI.Color("DSTextSecondary")
        static let border = SwiftUI.Color("DSBorder")
        static let destructive = SwiftUI.Color("DSDestructive")
        static let success = SwiftUI.Color.green
        static let warning = SwiftUI.Color.orange

        /// Zentrale Prioritätsfarbe (statt verstreuter tint-Zugriffe in Views).
        static func priority(_ priority: MemoPriority) -> SwiftUI.Color {
            priority.tint
        }
    }

    // MARK: Typografie (nur Dynamic-Type-Styles)

    enum Font {
        static let screenTitle = SwiftUI.Font.title2.bold()
        static let sectionHeader = SwiftUI.Font.headline
        static let body = SwiftUI.Font.body
        static let secondary = SwiftUI.Font.subheadline
        static let caption = SwiftUI.Font.caption
    }

    // MARK: Abstände (4-pt-Raster)

    enum Spacing {
        static let xs: CGFloat = 4
        static let s: CGFloat = 8
        static let m: CGFloat = 12
        static let l: CGFloat = 16
        static let xl: CGFloat = 24
        static let xxl: CGFloat = 32
    }

    // MARK: Radii

    enum Radius {
        static let card: CGFloat = 16
        static let control: CGFloat = 12
        static let chip: CGFloat = 8
    }
}

// MARK: - Karten-Look

extension View {
    /// Einheitlicher Card-Style: ersetzt detailCard() (DetailView/PreviewView),
    /// settingsSection() (SettingsView) und die Inline-Backgrounds in
    /// MemoCardView/HomeView.summaryHeader.
    func dsCard() -> some View {
        self
            .padding(DS.Spacing.l)
            .frame(maxWidth: .infinity, alignment: .leading)
            .background(
                DS.Color.card,
                in: RoundedRectangle(cornerRadius: DS.Radius.card, style: .continuous)
            )
            .overlay {
                RoundedRectangle(cornerRadius: DS.Radius.card, style: .continuous)
                    .strokeBorder(DS.Color.border)
            }
    }

    /// Badge-/Chip-Style für Kategorie- und Prioritäts-Labels.
    func dsChip(_ tint: Color) -> some View {
        self
            .font(DS.Font.caption.weight(.medium))
            .foregroundStyle(tint)
            .lineLimit(1)
            .padding(.horizontal, DS.Spacing.s)
            .padding(.vertical, DS.Spacing.xs)
            .background(tint.opacity(0.12), in: Capsule())
    }
}

// MARK: - Button-Styles

struct DSPrimaryButtonStyle: ButtonStyle {
    func makeBody(configuration: Configuration) -> some View {
        configuration.label
            .font(DS.Font.secondary.weight(.semibold))
            .foregroundStyle(.white)
            .frame(maxWidth: .infinity, minHeight: 44)
            .background(
                DS.Color.accent,
                in: RoundedRectangle(cornerRadius: DS.Radius.control, style: .continuous)
            )
            .opacity(configuration.isPressed ? 0.85 : 1)
            .scaleEffect(configuration.isPressed ? 0.97 : 1)
            .animation(.snappy(duration: 0.16), value: configuration.isPressed)
    }
}

struct DSSecondaryButtonStyle: ButtonStyle {
    func makeBody(configuration: Configuration) -> some View {
        configuration.label
            .font(DS.Font.secondary.weight(.semibold))
            .foregroundStyle(DS.Color.accent)
            .frame(maxWidth: .infinity, minHeight: 44)
            .background(
                DS.Color.accent.opacity(0.12),
                in: RoundedRectangle(cornerRadius: DS.Radius.control, style: .continuous)
            )
            .opacity(configuration.isPressed ? 0.7 : 1)
            .scaleEffect(configuration.isPressed ? 0.97 : 1)
            .animation(.snappy(duration: 0.16), value: configuration.isPressed)
    }
}

extension ButtonStyle where Self == DSPrimaryButtonStyle {
    static var dsPrimary: DSPrimaryButtonStyle { DSPrimaryButtonStyle() }
}

extension ButtonStyle where Self == DSSecondaryButtonStyle {
    static var dsSecondary: DSSecondaryButtonStyle { DSSecondaryButtonStyle() }
}

// MARK: - Empty State

struct DSEmptyState: View {
    let icon: String
    let title: String
    let message: String
    var actionTitle: String?
    var action: (() -> Void)?

    var body: some View {
        VStack(spacing: DS.Spacing.l) {
            Spacer()

            Image(systemName: icon)
                .font(.largeTitle.weight(.light))
                .imageScale(.large)
                .foregroundStyle(.tertiary)
                .accessibilityHidden(true)

            Text(title)
                .font(DS.Font.sectionHeader)

            Text(message)
                .font(DS.Font.secondary)
                .foregroundStyle(.secondary)
                .multilineTextAlignment(.center)
                .padding(.horizontal, DS.Spacing.xxl)

            if let actionTitle, let action {
                Button(actionTitle, action: action)
                    .buttonStyle(.dsPrimary)
                    .padding(.horizontal, DS.Spacing.xxl)
                    .padding(.top, DS.Spacing.s)
            }

            Spacer()
        }
    }
}

